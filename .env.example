# Salin ke .env lalu isi. .env TIDAK di-commit (rahasia).
# cp .env.example .env

# Password Postgres lokal (container db)
DB_PASSWORD=wellness

# Sumber rpt_trx (sistem access-control) — read-only
SOURCE_DATABASE_URL=postgres://USER:PASS@HOST:5432/TransactionDB
SOURCE_PGSSL=true

# Interval sync (detik) & batas backfill awal (hari)
SYNC_INTERVAL=5          # 5 dtk = near-realtime (ringan, reader tangga volume kecil)
SYNC_BACKFILL_DAYS=35
# 1 = hanya tap 'Valid Credential'. Default (kosong) = ikut 'Invalid Credential'
# supaya pemakai tangga yg kartunya belum di-enroll tetap terhitung (fase pengujian).
SYNC_VALID_ONLY=

# Dashboard (web)
WEB_PORT=3000            # ganti bila port host bentrok
DASHBOARD_TTL_SEC=10     # umur cache skor (dtk); FE auto-refresh 15 dtk
