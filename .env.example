# Salin ke .env lalu isi. .env TIDAK di-commit (rahasia).
# cp .env.example .env

# Password Postgres lokal (container db)
DB_PASSWORD=wellness

# Sumber rpt_trx (sistem access-control) — read-only
SOURCE_DATABASE_URL=postgres://USER:PASS@HOST:5432/TransactionDB
SOURCE_PGSSL=true

# Interval sync (detik) & batas backfill awal (hari)
SYNC_INTERVAL=3          # jeda worker tarik tap baru (min 2). 3 dtk ringan; reader volume kecil
SYNC_BACKFILL_DAYS=35
# 1 = hanya tap 'Valid Credential'. Default (kosong) = ikut 'Invalid Credential'
# supaya pemakai tangga yg kartunya belum di-enroll tetap terhitung (fase pengujian).
SYNC_VALID_ONLY=

# Environment (dev/prod terpisah) — beri nama & port beda per folder agar volume TIDAK bentrok.
# PROD: COMPOSE_PROJECT_NAME=wellness-prod + WEB_PORT=3000
# DEV : COMPOSE_PROJECT_NAME=wellness-dev  + WEB_PORT=3001
COMPOSE_PROJECT_NAME=wellness-prod

# RESET / titik-mulai program (opsional). Data (tap) SEBELUM timestamp ini disembunyikan
# dari dashboard TAPI tetap tersimpan di DB. Kosongkan/hapus baris ini utk menampilkan semua lagi (revert).
# Format WIB: "YYYY-MM-DD" atau "YYYY-MM-DD HH:MM" (mis. peluncuran resmi). Contoh:
# PROGRAM_START=2026-07-22 23:30
PROGRAM_START=

# Dashboard (web)
WEB_PORT=3000            # ganti bila port host bentrok (dev pakai 3001)
# Total jeda tap→layar ≈ SYNC_INTERVAL + DASHBOARD_TTL_SEC + DASHBOARD_REFRESH_SEC
DASHBOARD_TTL_SEC=3      # umur cache skor (dtk) — web hitung ulang paling cepat tiap sekian dtk
DASHBOARD_REFRESH_SEC=5  # interval auto-refresh browser (dtk, min 2)
# Profil "cepat" (≈10 dtk): SYNC_INTERVAL=3 · DASHBOARD_TTL_SEC=3 · DASHBOARD_REFRESH_SEC=5
# Profil "hemat"  (≈35 dtk): SYNC_INTERVAL=10 · DASHBOARD_TTL_SEC=20 · DASHBOARD_REFRESH_SEC=15
